@{
    ViewData["Title"] = "Uçuş Rezervasyonu";
}


<style>
    .booking-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        max-width: 700px;
        margin: 30px auto;
        padding: 20px;
        background-color: #f8f9fa;
        border-radius: 8px;
    }

    .flight-select {
        margin-bottom: 20px;
    }

    .flight-select select {
        padding: 8px;
        border-radius: 4px;
        border: 1px solid #ccc;
        width: 250px;
    }

    .legend {
        display: flex;
        gap: 20px;
        margin-bottom: 25px;
        font-size: 14px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .box {
        width: 20px;
        height: 20px;
        border-radius: 4px;
    }

    /* Rənglər */
    .bg-empty { background-color: #63b371; }    /* Yaşıl */
    .bg-selected { background-color: #4a90e2; } /* Mavi */
    .bg-full { background-color: #d9534f; }     /* Qırmızı */

    .plane-body {
        background: white;
        border-radius: 60px 60px 15px 15px;
        padding: 40px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
    }

    .pilot-cabin {
        text-align: center;
        background: #f0f0f0;
        padding: 20px;
        border-radius: 40px 40px 10px 10px;
        margin-bottom: 40px;
        font-size: 24px;
        color: #666;
        font-weight: 300;
    }

    .seats-container {
        display: flex;
        justify-content: center;
        gap: 40px; /* Keçid (aisle) boşluğu */
    }

    .seat-group {
        display: grid;
        grid-template-columns: repeat(3, 35px);
        gap: 10px;
    }

    .seat {
        width: 35px;
        height: 35px;
        border-radius: 6px;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .seat:hover {
        transform: scale(1.1);
    }

    .summary-section {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #eee;
    }

    .btn-reserve {
        background-color: #4a90e2;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 5px;
        font-size: 16px;
        cursor: pointer;
        margin-top: 15px;
    }

    .btn-reserve:hover {
        background-color: #357abd;
    }
</style>

<div class="booking-container">
    <div class="flight-select">
        <label>Uçuş istiqaməti: </label>
        <select id="locationSelect">
            <option value="450">Bakı - London (450 AZN)</option>
            <option value="200">Bakı - İstanbul (200 AZN)</option>
        </select>
    </div>

    <div class="legend">
        <div class="legend-item"><div class="box bg-empty"></div> Boş</div>
        <div class="legend-item"><div class="box bg-selected"></div> Seçdiyiniz</div>
        <div class="legend-item"><div class="box bg-full"></div> Dolu</div>
    </div>

    <div class="plane-body">
        <div class="pilot-cabin">Pilot Kabini</div>
        <div class="seats-container">
            <div class="seat-group">
                <div class="seat bg-empty" data-num="A1"></div>
                <div class="seat bg-empty" data-num="A2"></div>
                <div class="seat bg-empty" data-num="A3"></div>
                <div class="seat bg-full" data-num="A4"></div>
                <div class="seat bg-full" data-num="A5"></div>
                <div class="seat bg-empty" data-num="A6"></div>
            </div>
            <div class="seat-group">
                <div class="seat bg-empty" data-num="B1"></div>
                <div class="seat bg-empty" data-num="B2"></div>
                <div class="seat bg-empty" data-num="B3"></div>
                <div class="seat bg-empty" data-num="B4"></div>
                <div class="seat bg-empty" data-num="B5"></div>
                <div class="seat bg-empty" data-num="B6"></div>
            </div>
        </div>
    </div>

    <div class="summary-section">
        <p>Seçilən yer sayı: <strong id="countDisp">0</strong></p>
        <p>Ümumi qiymət: <strong id="priceDisp">0</strong> AZN</p>
        <button class="btn-reserve" onclick="reserveSeats()">Rezerv et</button>
    </div>
</div>

<script>
    let selectedSeats = [];
    const getPricePerSeat = () => parseInt(document.getElementById('locationSelect').value);

    // Oturacaq seçimi
    document.querySelectorAll('.seat').forEach(seat => {
        seat.addEventListener('click', function() {
            if (this.classList.contains('bg-full')) return; // Dolu yerə klik etmək olmaz

            const seatNum = this.getAttribute('data-num');

            if (this.classList.contains('bg-empty')) {
                this.classList.replace('bg-empty', 'bg-selected');
                selectedSeats.push(seatNum);
            } else {
                this.classList.replace('bg-selected', 'bg-empty');
                selectedSeats = selectedSeats.filter(s => s !== seatNum);
            }
            
            document.getElementById('countDisp').innerText = selectedSeats.length;
            document.getElementById('priceDisp').innerText = selectedSeats.length * getPricePerSeat();
        });
    });

    // Məlumatı bazaya göndər
  async function reserveSeats() {
    if (selectedSeats.length === 0) {
        alert("Zəhmət olmasa yer seçin!");
        return;
    }

    const totalAmount = document.getElementById('priceDisp').innerText;
    const destination = document.getElementById('locationSelect').selectedOptions[0].text;

    const data = {
        Location: destination,
        Count: selectedSeats.length,
        Price: parseInt(totalAmount),
        SideNumber: selectedSeats.join(', ')
    };

    const response = await fetch('/Home/Reserve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });

    if (response.ok) {
        alert(`🎫 BİLET ALINDI!\n\nYerlər: ${data.SideNumber}`);

        // --- YENİ HİSSƏ: Seçilən yerləri qırmızı (dolu) et ---
        document.querySelectorAll('.seat.bg-selected').forEach(seat => {
            seat.classList.remove('bg-selected');
            seat.classList.add('bg-full'); // Qırmızı rəng klası
            seat.style.cursor = "not-allowed"; // Artıq klikləmək olmasın
        });

        // Seçimləri və ekranı sıfırla
        selectedSeats = [];
        document.getElementById('countDisp').innerText = "0";
        document.getElementById('priceDisp').innerText = "0";
        
        // Artıq location.reload() etmirik ki, qırmızı yerlər itməsin!
    } else {
        alert("Xəta baş verdi.");
    }
}
</script>